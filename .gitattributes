# Handle line endings automatically
* text=auto

# Java source files — LF in repo, auto-convert on checkout
*.java text eol=lf
*.gradle text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.json text eol=lf

# Windows scripts — CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary files — no conversion
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.zip binary
